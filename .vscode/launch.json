    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "AST Compiler",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}\\root\\ast\\compiler.js"
        },
        {
            "name": "Inspect",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}\\root\\inspect.js"
        }
    ]
}